####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/ui/bin || mkdir -p $(INSTALL_ROOT)/opt/ui/bin
	$(QINSTALL_PROGRAM) build/out/$(QMAKE_TARGET) $(INSTALL_ROOT)/opt/ui/bin/$(QMAKE_TARGET)
	-$(STRIP) $(INSTALL_ROOT)/opt/ui/bin/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) $(INSTALL_ROOT)/opt/ui/bin/$(QMAKE_TARGET)
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/ui/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

FORCE:

