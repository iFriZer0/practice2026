@startuml l_2

!include <C4/C4_Container>

!theme plain

UpdateElementStyle(Person, $borderColor="#000000", $fontColor="#000000", $bgColor="#ffffff")
UpdateElementStyle(Container, $borderColor="#000000", $fontColor="#000000", $bgColor="#ffffff")


Person(user, "Пользователь", "Взаимодействует с платой")

System_Boundary(workplace, "Система взаимодействия с платой") {
    Container(main, "Основная программа", "", "Точка входа в систему")
    Container(rs485_service, "Микросервис для работы с RS-485", "", "Обращается к драйверу RS-485")
    Container(mko_service, "Микросервис для работы с МКО", "", "Обращается к драйверу МКО")
    Container(pku_service, "Микросервис для работы с РК/ПКУ", "", "Обращается к драйверу РК/ПКУ")
    Container(rs485_driver, "Драйвер RS-485", "С++", "Обращается к плате")
    Container(mko_driver, "Драйвер МКО", "С++", "Обращается к плате")
    Container(pku_driver, "Драйвер РК/ПКУ", "C++", "Обращается к плате")
}


System(board, "Плата", "Отвечает на запросы")

Rel(user, workplace, "Взаимодействует с платой")
Rel(workplace, board, "Отправляет запросы")


@enduml